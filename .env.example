# Digital Filing Cabinet — Environment Configuration
# Copy to .env and customize as needed

# ===========================================
# REQUIRED
# ===========================================
DB_PATH=./lancedb_data

# ===========================================
# LLM PROVIDER (default: ollama, local)
# ===========================================
LLM_PROVIDER=ollama
OLLAMA_MODEL=phi4-mini
OLLAMA_HOST=http://localhost:11434

# Vision Provider (default: ollama, local)
VISION_PROVIDER=ollama
OLLAMA_VISION_MODEL=qwen3-vl:8b

# ===========================================
# PERFORMANCE TUNING
# ===========================================
# EMBED_BATCH_SIZE=64          # Lower for less RAM usage
# LLM_TIMEOUT=120              # Seconds, increase for slower machines
# OLLAMA_NUM_CTX=4096          # Context window, increase for longer docs
# EMBED_MODEL_NAME=BAAI/bge-small-en-v1.5
# RERANK_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2

# ===========================================
# OPTIONAL: Cloud Providers
# Uncomment ONLY if you want cloud LLMs
# ===========================================
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL_ID=gpt-5-nano-2025-08-07

# VISION_PROVIDER=gemini
# GEMINI_API_KEY=AIza...
