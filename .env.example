# LLM Provider Configuration
# ---------------------------
# Choose your LLM provider: "openai" (cloud) or "ollama" (local)
LLM_PROVIDER=openai

# OpenAI Settings (when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Ollama Settings (when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:8b

# Vision Provider Configuration
# -----------------------------
# Choose your vision provider: "gemini" (cloud) or "ollama" (local)
VISION_PROVIDER=gemini

# Gemini Settings (when VISION_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_VISION_MODEL=gemini-2.0-flash

# Ollama Vision Settings (when VISION_PROVIDER=ollama)
OLLAMA_VISION_MODEL=llava:13b

# API Security
# ------------
API_SECRET=your-secret-api-key-here
ADMIN_PASSWORD=your-admin-password-here

# CORS Settings
# -------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Workspace Settings
# ------------------
DEFAULT_WORKSPACE_ID=default
